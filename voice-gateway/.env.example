# Voice Gateway Environment Configuration
# v2.0.0

# ============================================
# Server
# ============================================
HOST=0.0.0.0
PORT=8080

# ============================================
# AWS Configuration
# ============================================
AWS_REGION=ap-northeast-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key

# ============================================
# Amazon Transcribe (STT)
# ============================================
TRANSCRIBE_LANGUAGE_CODE=ja-JP
TRANSCRIBE_SAMPLE_RATE=16000

# ============================================
# Amazon Polly (TTS)
# ============================================
POLLY_VOICE_ID=Takumi
POLLY_SAMPLE_RATE=8000
POLLY_ENGINE=neural

# ============================================
# Rasa Configuration
# ============================================
RASA_URL=http://rasa:5005
RASA_REST_ENDPOINT=http://rasa:5005/webhooks/rest/webhook
RASA_TIMEOUT=20.0

# ============================================
# Dify Configuration
# ============================================
DIFY_API_URL=http://dify-api:5001/v1
DIFY_API_KEY=your_dify_api_key
DIFY_TIMEOUT=30.0

# ============================================
# FreeSWITCH ESL Configuration
# ============================================
FREESWITCH_HOST=freeswitch
FREESWITCH_PORT=8021
FREESWITCH_PASSWORD=ClueCon
FREESWITCH_DOMAIN=freeswitch

# ============================================
# Audio Processing
# ============================================
AUDIO_QUEUE_MAX=50
