# --------------------------
# Step2: FreeSWITCH build/install
# --------------------------
# SignalWire Personal Access Token (PAT) is required by fsget to install FreeSWITCH Debian packages.
# Safer option: use BuildKit secret instead of putting PAT here (see README).
SIGNALWIRE_PAT=pat_j8N2RNuGZDLV8wpWKXA2FLmm

# Optional: FreeSWITCH channel / meta package
FS_CHANNEL=release
FS_ACTION=install
FS_META_PACKAGE=freeswitch-meta-all

# If running on a cloud VM behind NAT, set these to your public IP (EIP).
# If empty, FreeSWITCH will fall back to container/host local IP and NAT may break audio.
EXTERNAL_SIP_IP=126.19.122.165
EXTERNAL_RTP_IP=126.19.122.165

# Where FreeSWITCH pushes audio frames (inside compose network)
AUDIO_WS_URL=ws://voice-gateway:8080/ws

# --------------------------
# Step3: voice-gateway (AWS Transcribe Streaming + Polly)
# --------------------------
AWS_REGION=ap-northeast-1
TRANSCRIBE_LANGUAGE_CODE=ja-JP
TRANSCRIBE_SAMPLE_RATE=16000
POLLY_VOICE_ID=Takumi
POLLY_SAMPLE_RATE=8000
AUDIO_QUEUE_MAX=50
LOG_LEVEL=INFO
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# If you also start the rasa service, keep this default.
RASA_REST_ENDPOINT=http://host.docker.internal:5005/webhooks/rest/webhook

# voice-gateway listen
BIND_HOST=0.0.0.0
BIND_PORT=8080

# Optional: mount AWS shared config/credentials for local dev.
# Put credentials under ./aws/credentials and config under ./aws/config.
AWS_SHARED_DIR=./aws

# Optional: mount your Rasa project when using --profile rasa
RASA_PROJECT_DIR=./rasa_project

# .env に追加
# ============================================
# FusionPBX 設定
# ============================================
FUSIONPBX_DB_USER=fusionpbx
FUSIONPBX_DB_PASSWORD=your_secure_password_here
FUSIONPBX_DB_NAME=fusionpbx
FUSIONPBX_DOMAIN=localhost

# FreeSWITCH ESL パスワード
ESL_PASSWORD=ClueCon
