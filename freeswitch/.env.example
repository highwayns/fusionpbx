# ---- Build / install ----
# SignalWire Personal Access Token (PAT) for fsget
SIGNALWIRE_PAT=

# FreeSWITCH channel used by fsget: release / prerelease
FS_CHANNEL=release
FS_ACTION=install
FS_META_PACKAGE=freeswitch-meta-all

# ---- Runtime ----
# If running behind NAT (cloud VM), set these to your public IP (Elastic IP recommended)
EXTERNAL_SIP_IP=
EXTERNAL_RTP_IP=

# Where mod_audio_stream pushes audio frames (your voice-gateway WebSocket)
AUDIO_WS_URL=ws://voice-gateway:8080/ws

# Optional: mount dirs for example services
RASA_PROJECT_DIR=./rasa_project
VOICE_GATEWAY_DIR=./voice-gateway
